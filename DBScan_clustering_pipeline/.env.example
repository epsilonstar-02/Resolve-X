# Database
DATABASE_URL=postgresql://user:password@localhost:5432/resolvex
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10

# App metadata
APP_TITLE=ResolveX DBSCAN Clustering Service
APP_VERSION=1.0.0
APP_DESCRIPTION=Standalone microservice that exposes spatial complaint clustering as GeoJSON FeatureCollection.
SERVICE_NAME=dbscan-clustering

# Clustering behavior
LOOKBACK_DAYS=30
MIN_COMPLAINTS_REQUIRED=3
SEARCH_RADIUS_KM=0.5
DBSCAN_MIN_SAMPLES=3
TRUST_WEIGHT_THRESHOLD=0.60
EARTH_RADIUS_KM=6371.0
